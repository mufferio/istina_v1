# Istina Configuration
# Copy this to .env and set your actual values

# Environment: dev, test, or prod  
ISTINA_ENV=dev

# Provider selection: mock, gemini
ISTINA_PROVIDER=mock

# Repository type: memory, file
ISTINA_REPO_TYPE=memory

# Logging level
ISTINA_LOG_LEVEL=INFO

# Data directory for file storage
ISTINA_DATA_DIR=./data

# Rate limiting (requests per minute)
ISTINA_RATE_LIMIT_RPM=60

# === Gemini API Configuration ===
# Required when using ISTINA_PROVIDER=gemini
# Get your API key from: https://makersuite.google.com/app/apikey
ISTINA_GEMINI_API_KEY=your-gemini-api-key-here

# Gemini model to use (optional, defaults to gemini-2.5-flash)
ISTINA_GEMINI_MODEL=gemini-2.5-flash